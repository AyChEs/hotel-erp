# ----- Backend (prod) -----
# Neon pooled connection string
DB_URL=jdbc:postgresql://<endpoint>-pooler.<region>.aws.neon.tech/hotelerp?sslmode=require
DB_USERNAME=hotelerp
DB_PASSWORD=change-me

# JWT — generate with: openssl rand -base64 48
APP_JWT_SECRET=change-me-base64-256bit-minimum
APP_JWT_ACCESS_TTL=PT15M
APP_JWT_REFRESH_TTL=P7D

# CORS — exact frontend origin (no trailing slash), comma-separated for several
APP_CORS_ORIGINS=https://hotel-erp.vercel.app

# SMTP (Brevo)
APP_MAIL_ENABLED=true
APP_MAIL_FROM=no-reply@your-domain.dev
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login
MAIL_PASSWORD=your-brevo-smtp-key

# ----- Frontend -----
VITE_API_URL=https://hotel-erp-api.onrender.com
